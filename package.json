{
  "name": "pi-codex-adaptor",
  "version": "0.0.0",
  "description": "A Pi extension that adapts the official OpenAI Codex runtime contract.",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizuikki/pi-codex-adaptor.git"
  },
  "bugs": {
    "url": "https://github.com/mizuikki/pi-codex-adaptor/issues"
  },
  "homepage": "https://github.com/mizuikki/pi-codex-adaptor#readme",
  "keywords": [
    "codex",
    "openai",
    "pi",
    "pi-package"
  ],
  "files": [
    "LICENSE",
    "README.md",
    "native/bin",
    "src"
  ],
  "pi": {
    "extensions": [
      "./src/extension.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "@types/node": "24.13.3"
  },
  "scripts": {
    "check": "bun run lint && bun run typecheck && bun run check:architecture && bun run check:native && bun test && bun run check:toolchain && bun run check:app-server-schema && bun run check:upstream && bun run check:official-workspace && bun run check:sbom && bun run test:official && bun run pack:verify",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "check:toolchain": "bun scripts/verify-toolchain.ts",
    "check:app-server-schema": "bun scripts/verify-app-server-schema.ts",
    "check:upstream": "bun scripts/sync-codex-upstream.ts --verify",
    "check:upstream-source": "bun scripts/sync-codex-upstream.ts --verify-source",
    "check:official-workspace": "bun scripts/generate-official-workspace.ts --check",
    "check:sbom": "bun scripts/generate-native-sbom.ts --check",
    "test:official": "bun scripts/generate-official-fixtures.ts --check",
    "check:native": "bun scripts/check-native.ts",
    "test:bridge": "bun scripts/check-native.ts",
    "build:native": "bun scripts/build-native.ts",
    "pack:assemble": "bun scripts/assemble-package.ts",
    "pack:verify": "bun scripts/verify-package.ts",
    "release:verify": "bun scripts/verify-release.ts",
    "release": "bun scripts/publish-package.ts",
    "check:architecture": "bun scripts/check-architecture.ts",
    "test:integration": "bun test tests/integration",
    "test:smoke": "bun test tests/smoke"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@earendil-works/pi-agent-core": "0.80.7",
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "@openai/codex": "0.144.3",
    "@openai/codex-sdk": "0.144.3",
    "@types/bun": "1.3.14",
    "@types/node": "^24.13.3",
    "smol-toml": "1.7.0",
    "typebox": "1.3.6",
    "typescript": "^7.0.2",
    "yaml": "2.9.0"
  }
}
